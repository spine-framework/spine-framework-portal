[
  {
    "kind": "item",
    "slug": "community_post",
    "name": "Community Post",
    "description": "Community discussion post with voting and accepted answers",
    "icon": "message-circle",
    "color": "#6366F1",
    "ownership": "tenant",
    "is_active": true,
    "design_schema": {
      "scope": "platform",
      "views": {
        "default_list": {
          "type": "list",
          "label": "Community Posts",
