{
  "name": "spine-framework-portal",
  "version": "1.0.0",
  "description": "Self-service portal for customers to access tickets, knowledge base, courses, and community built on Spine Framework",
  "main": "custom/apps/customer-portal/index.tsx",
  "homepage": "https://spine-framework.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/spine-framework/spine-framework-portal.git"
  },
  "keywords": [
    "spine-framework",
    "customer-portal",
    "self-service",
    "tickets",
    "knowledge-base",
    "courses",
    "community",
    "marketplace",
    "customer-support"
  ],
  "author": "Dahl Ventures Inc.",
  "license": "SEE LICENSE IN LICENSE.md",
  "files": [
    "custom/apps/customer-portal/**/*",
    "LICENSE.md",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "spine-framework": "^1.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "@spine-framework/core": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "type-check": "tsc --noEmit",
    "lint": "eslint custom/apps/customer-portal --ext .ts,.tsx",
    "test": "vitest"
  },
  "exports": {
    ".": {
      "types": "./custom/apps/customer-portal/index.tsx",
      "default": "./custom/apps/customer-portal/index.tsx"
    },
    "./components": {
      "types": "./custom/apps/customer-portal/components/index.ts",
      "default": "./custom/apps/customer-portal/components/index.ts"
    },
    "./hooks": {
      "types": "./custom/apps/customer-portal/hooks/index.ts",
      "default": "./custom/apps/customer-portal/hooks/index.ts"
    },
    "./types": {
      "types": "./custom/apps/customer-portal/types/index.ts",
      "default": "./custom/apps/customer-portal/types/index.ts"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "spine": {
    "app": {
      "slug": "customer-portal",
      "name": "Customer Portal",
      "version": "1.0.0",
      "entry": "custom/apps/customer-portal/index.tsx",
      "manifest": "custom/apps/customer-portal/manifest.json",
      "requiredRoles": ["member"],
      "routePrefix": "/portal",
      "renderer": "custom",
      "isPublic": true,
      "authRequired": true
    },
    "compatibility": {
      "framework": "^1.0.0",
      "node": ">=18.0.0"
    }
  }
}
