{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["../.assembled/src/*"],              // Assembled frontend
      "@core/*": ["../.framework/src/*"],     // Core source
      "@custom/*": ["../custom/*"], // Custom source
      "@shared/*": ["../.framework/functions/_shared/*"] // Shared functions (resolved at runtime via assembly)
    }
  },
  "include": [".assembled/src", ".framework/functions"],
  "exclude": [
    "node_modules",
    "dist",
    "netlify/functions",
    "supabase",
    "scripts",
    ".netlify",
    ".assembled/src",
    "custom/functions"
  ],
  "references": [{ "path": "./tsconfig.node.json" }]
}
